{
    "name": "aryeo/event-log",
    "type": "library",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        },
        "actions": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/actions"
        }
    },
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.37",
        "aryeo/actions": "0.0.13"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "aryeo/tooling-laravel": "0.0.36",
        "brianium/paratest": "^7.14",
        "phpunit/phpunit": "^12.4.1",
        "pestphp/pest": "^4.1",
        "orchestra/testbench-core": "^10.7",
        "nesbot/carbon": "^3.10",
        "nunomaduro/collision": "<8.9.4"
    },
    "autoload": {
        "psr-4": {
            "Support\\": "src/Support",
            "Tooling\\": "src/Tooling"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "aryeo/tooling-laravel": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Support\\Events\\Log\\Providers\\Provider"
            ]
        },
        "tooling": {
            "phpstan": "tooling/phpstan/rules.neon"
        }
    }
}
